# MAKE IR. CLANG TURN C CODE INTO LLVM WORDS. READ WORDS LATER.
# CLANG SPELL: -S MEAN STOP BEFORE ASSEMBLE. -EMIT-LLVM MEAN WRITE WORDS NOT MACHINE.
# -O0 MEAN NO TRICK. -G MEAN KEEP NAMES. NEED NAMES TO FIND STRUCT.

CC      = clang
CFLAGS  = -S -emit-llvm -O0 -g

# FIND ALL C FILES IN BENCHMARK DIR. WANT ALL.
SRCS    := $(wildcard ../c_benchmark/*.c)

# TURN EACH C FILE NAME INTO LL FILE NAME. MAGIC SUBSTITUTION.
NAMES   := $(patsubst ../c_benchmark/%.c,%,$(SRCS))
LLFILES := $(patsubst %,ir/%.ll,$(NAMES))

.PHONY: ir clean

# IR TARGET. BUILD ALL LL FILES. THEN DONE.
ir: $(LLFILES)

# RULE: ONE C FILE GO IN, ONE LL FILE COME OUT.
# MKDIR FIRST IN CASE IR/ DIR NOT EXIST.
ir/%.ll: ../c_benchmark/%.c
	mkdir -p ir
	$(CC) $(CFLAGS) $< -o $@

# CLEAN TARGET. THROW AWAY OLD IR. START FRESH.
# KEEP DIR ITSELF. ONLY DELETE LL FILES.
clean:
	rm -f ir/*.ll
